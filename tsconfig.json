{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "ES2020",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "types": ["node"],
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "ts-node": {
    "esm": false,
    "skipProject": true
  }
}
